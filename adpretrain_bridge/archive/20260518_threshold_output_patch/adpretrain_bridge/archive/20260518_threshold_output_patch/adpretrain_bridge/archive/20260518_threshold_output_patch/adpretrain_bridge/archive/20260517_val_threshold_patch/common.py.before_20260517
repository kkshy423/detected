import os
import sys
import json
import shutil
from contextlib import contextmanager
from pathlib import Path
from typing import Dict, Iterable, List, Sequence, Tuple

import numpy as np
import torch
import torch.nn.functional as F
from PIL import Image
from torchvision import transforms


IMAGE_EXTS = {'.bmp', '.png', '.jpg', '.jpeg', '.tif', '.tiff'}


def add_adpretrain_to_path(adpretrain_root: str) -> None:
    root = str(Path(adpretrain_root).resolve())
    if root not in sys.path:
        sys.path.insert(0, root)




@contextmanager
def working_directory(path: str):
    old = os.getcwd()
    os.chdir(path)
    try:
        yield
    finally:
        os.chdir(old)

def list_image_files(root: Path) -> List[Path]:
    if not root.exists():
        return []
    files = [p for p in root.iterdir() if p.is_file() and p.suffix.lower() in IMAGE_EXTS]
    return sorted(files, key=lambda p: p.name)


def iter_mvtec_images(class_root: Path, split: str) -> Iterable[Tuple[str, Path]]:
    split_root = class_root / split
    for defect_dir in sorted([p for p in split_root.iterdir() if p.is_dir()], key=lambda p: p.name):
        for img_path in list_image_files(defect_dir):
            rel_no_suffix = str(Path(split) / defect_dir.name / img_path.stem)
            yield rel_no_suffix, img_path


def ensure_dataset_links(src_class_root: Path, dst_class_root: Path) -> None:
    dst_class_root.mkdir(parents=True, exist_ok=True)
    for name in ['train', 'test', 'ground_truth']:
        src = src_class_root / name
        dst = dst_class_root / name
        if dst.exists() or dst.is_symlink():
            continue
        if src.exists():
            try:
                dst.symlink_to(src, target_is_directory=True)
            except OSError:
                if src.is_dir():
                    shutil.copytree(src, dst)
                else:
                    shutil.copy2(src, dst)


def build_transform(backbone: str):
    if backbone == 'imagebind' or 'clip' in backbone:
        mean = (0.48145466, 0.4578275, 0.40821073)
        std = (0.26862954, 0.26130258, 0.27577711)
    else:
        mean = (0.485, 0.456, 0.406)
        std = (0.229, 0.224, 0.225)
    return transforms.Compose([
        transforms.Resize(224, transforms.InterpolationMode.BICUBIC),
        transforms.CenterCrop(224),
        transforms.ToTensor(),
        transforms.Normalize(mean=mean, std=std),
    ])


def load_image_tensor(path: Path, transform, device: torch.device) -> torch.Tensor:
    with Image.open(path) as img:
        img = img.convert('RGB')
        return transform(img).unsqueeze(0).to(device)


def make_encoder(backbone: str, adpretrain_root: str, device: torch.device):
    add_adpretrain_to_path(adpretrain_root)
    with working_directory(adpretrain_root):
        if backbone in {'dinov2-base', 'dinov2-large'}:
            from models.dino import DinoModel
            encoder = DinoModel(backbone, device=str(device))
        elif backbone in {'clip-base', 'clip-large'}:
            from models.clip import ClipModel
            encoder = ClipModel(backbone, device=str(device))
        elif backbone == 'imagebind':
            from models.imagebind import ImageBindModel
            encoder = ImageBindModel(backbone, device=str(device))
        else:
            raise ValueError(f'Unsupported backbone: {backbone}')
    encoder.to(device)
    encoder.eval()
    return encoder


def encode_multiscale(encoder, batch: torch.Tensor) -> List[torch.Tensor]:
    if hasattr(encoder, 'encode_image_from_tensors'):
        return list(encoder.encode_image_from_tensors(batch, return_global=False, shape='img'))
    out = encoder(batch)
    if isinstance(out, tuple):
        out = out[-1]
    return list(out)


def make_projector(encoder, adpretrain_root: str, checkpoint_path: str, device: torch.device):
    add_adpretrain_to_path(adpretrain_root)
    with working_directory(adpretrain_root):
        from models.projector import MultiScaleAttentionProjector
        projector = MultiScaleAttentionProjector(encoder.feature_dimensions, device=str(device))
    if checkpoint_path:
        ckpt = torch.load(checkpoint_path, map_location='cpu')
        state = ckpt.get('projectors', ckpt)
        projector.load_state_dict(state, strict=True)
    projector.to(device)
    projector.eval()
    return projector


def flatten_feature_map(feature: torch.Tensor) -> torch.Tensor:
    b, c, h, w = feature.shape
    return feature.permute(0, 2, 3, 1).reshape(-1, c).contiguous()


def build_reference_features(
    encoder,
    image_paths: Sequence[Path],
    transform,
    device: torch.device,
    num_ref: int,
) -> List[torch.Tensor]:
    selected = list(image_paths)[:num_ref]
    if not selected:
        raise ValueError('No reference images found in train/good')
    refs = None
    with torch.no_grad():
        for path in selected:
            batch = load_image_tensor(path, transform, device)
            features = encode_multiscale(encoder, batch)
            flat = [flatten_feature_map(x).detach() for x in features]
            if refs is None:
                refs = [[] for _ in flat]
            for idx, item in enumerate(flat):
                refs[idx].append(item)
    return [torch.cat(items, dim=0).to(device) for items in refs]


def match_reference_features(features: Sequence[torch.Tensor], refs: Sequence[torch.Tensor]) -> List[torch.Tensor]:
    matched = []
    for feature, ref in zip(features, refs):
        b, c, h, w = feature.shape
        flat = feature.permute(0, 2, 3, 1).reshape(-1, c).contiguous()
        flat_n = F.normalize(flat, p=2, dim=1)
        ref_n = F.normalize(ref, p=2, dim=1)
        index = torch.argmax(flat_n @ ref_n.T, dim=1)
        picked = ref[index].reshape(b, h, w, c).permute(0, 3, 1, 2).contiguous()
        matched.append(picked)
    return matched


def residual_features(features: Sequence[torch.Tensor], refs: Sequence[torch.Tensor]) -> List[torch.Tensor]:
    return [x - r for x, r in zip(features, refs)]


def project_to_512(feature: torch.Tensor) -> torch.Tensor:
    c = feature.shape[1]
    if c == 512:
        return feature
    if c > 512:
        return feature[:, :512]
    pad = torch.zeros(feature.shape[0], 512 - c, feature.shape[2], feature.shape[3], device=feature.device, dtype=feature.dtype)
    return torch.cat([feature, pad], dim=1)


def resize_feature(feature: torch.Tensor, size: Tuple[int, int]) -> torch.Tensor:
    if tuple(feature.shape[-2:]) == tuple(size):
        return feature
    return F.interpolate(feature, size=size, mode='bilinear', align_corners=False)


def compress_four_to_two(features: Sequence[torch.Tensor]) -> Tuple[torch.Tensor, torch.Tensor]:
    if len(features) != 4:
        raise ValueError(f'Expected 4 feature layers, got {len(features)}')
    projected = [project_to_512(x.float()) for x in features]
    l1 = resize_feature(projected[0], (7, 7))
    l2 = resize_feature(projected[1], (7, 7))
    l3 = resize_feature(projected[2], (14, 14))
    l4 = resize_feature(projected[3], (14, 14))
    feature_scale = (l1 + l2) / 2.0
    feature = (l3 + l4) / 2.0
    return feature, feature_scale


def save_feature_pair(output_class_root: Path, rel_no_suffix: str, feature: torch.Tensor, feature_scale: torch.Tensor) -> None:
    arr = feature.squeeze(0).detach().cpu().numpy().astype(np.float32)
    arr_scale = feature_scale.squeeze(0).detach().cpu().numpy().astype(np.float32)
    feature_path = output_class_root / 'feature' / f'{rel_no_suffix}.npy'
    scale_path = output_class_root / 'feature_scale' / f'{rel_no_suffix}.npy'
    feature_path.parent.mkdir(parents=True, exist_ok=True)
    scale_path.parent.mkdir(parents=True, exist_ok=True)
    np.save(feature_path, arr)
    np.save(scale_path, arr_scale)


def write_json(path: Path, payload: Dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open('w', encoding='utf-8') as f:
        json.dump(payload, f, ensure_ascii=False, indent=2)